(1 row)

SELECT count(*) FROM yaml_gin_test WHERE data ?& ARRAY['k','v'];
 count 
-------
    51
(1 row)

SELECT id FROM yaml_gin_test WHERE data @? '$.k ? (@ == "target")';
 id 
----
